=======

>>>>>>> 9bf4979 (Inicializar repositório com todos os módulos Python)

# URL base da API do Grok (padrão: https://api.x.ai/v1)
GROK_API_BASE_URL=https://api.x.ai/v1

# Host do servidor FastAPI (padrão: 127.0.0.1)
HOST=0.0.0.0

# Porta do servidor FastAPI (padrão: 8000)
PORT=8000

# Modo de depuração (true/false, padrão: false)
DEBUG=false

# Origens permitidas para CORS (separadas por vírgula, padrão: [])
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080

# Hosts permitidos (separados por vírgula, para middleware de segurança, padrão: *)
ALLOWED_HOSTS=*

# Nível de log (DEBUG, INFO, WARNING, ERROR, padrão: INFO)
LOG_LEVEL=INFO

# Outras variáveis úteis (ex: para banco de dados, se usado no app.py)
# DATABASE_URL=postgresql://user:pass@localhost/dbname
EOF